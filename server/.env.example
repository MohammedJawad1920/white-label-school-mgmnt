# =====================================================
# WHITE-LABEL SCHOOL MANAGEMENT — ENV EXAMPLE v3.3
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =====================================================

# ── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL required) ───────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/school_mgmt"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Authentication ────────────────────────────────
# JWT_SECRET: MUST be >= 32 characters (256-bit entropy minimum)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-this-with-a-real-256-bit-secret-min-32-chars"
# JWT_EXPIRES_IN: minimum 7d, must match pattern /^\d+d$/
JWT_EXPIRES_IN="365d"
# BCRYPT_ROUNDS: must be 10, 11, or 12
BCRYPT_ROUNDS=10

# ── CORS (comma-separated allowed origins) ────────
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"

# ── Logging ───────────────────────────────────────
LOG_LEVEL="info"

# ── SuperAdmin Seed (used by npm run seed:superadmin) ──
# Override before running the seed script in production.
# SA_SEED_EMAIL=admin@platform.com
# SA_SEED_PASSWORD=SuperAdmin@123
# SA_SEED_NAME=Platform Admin
