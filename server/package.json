{
  "name": "white-label-school-mgmt-server",
  "version": "3.5.0",
  "description": "White-Label School Management System — Backend v3.5",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed:superadmin": "ts-node src/db/seeds/superadmin.ts",
    "migrate": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/001_initial_schema.sql', {stdio:'inherit', shell:true})\"",
    "migrate:002": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/002_add_student_user_id.sql', {stdio:'inherit', shell:true})\"",
    "migrate:003": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/003_add_attendance_corrections.sql', {stdio:'inherit', shell:true})\"",
    "migrate:004": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/004_student_admission_dob.sql', {stdio:'inherit', shell:true})\"",
    "migrate:005": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/005_tenant_timezone.sql', {stdio:'inherit', shell:true})\"",
    "migrate:006": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/006_student_status_classid_nullable.sql', {stdio:'inherit', shell:true})\"",
    "migrate:007": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/007_batch_status_graduated.sql', {stdio:'inherit', shell:true})\"",
    "migrate:008": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/008_timeslot_remove_effective_dates.sql', {stdio:'inherit', shell:true})\"",
    "migrate:009": "node -r dotenv/config -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f src/db/migrations/009_academic_calendar_events.sql', {stdio:'inherit', shell:true})\"",
    "mock": "npx @stoplight/prism-cli@5.14.2 mock ./docs/openapi.yaml --port 4010",
    "mock:verbose": "npx @stoplight/prism-cli@5.14.2 mock ./docs/openapi.yaml --port 4010 --errors",
    "test": "jest --runInBand",
    "test:integration": "jest --config jest.config.integration.ts --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@types/jest": "^29.5.14",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.11.5",
    "ts-jest": "^29.2.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
