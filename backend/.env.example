# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/schoolmgmt?schema=public

# Authentication
JWT_SECRET=minimum-32-character-secret-key-change-in-production
JWT_EXPIRES_IN=1d
OTP_EXPIRES_IN=300

# Email Service (for OTP)
EMAIL_SERVICE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@school.com

# Rate Limiting
OTP_REQUEST_LIMIT=3
OTP_VERIFY_LIMIT=5

# PWA Configuration
PWA_CACHE_VERSION=v1
OFFLINE_QUEUE_MAX_SIZE=100

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Uploads (if file storage added later)
MAX_FILE_SIZE=10485760
